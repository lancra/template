{
  "$id": "https://raw.githubusercontent.com/lancra/template/main/.template/note.schema.json",
  "executions": [
    {
      "display": "Resolving global packages conflict.",
      "stage": "pick",
      "commands": [
        "$repository/.template/scripts/resolve-conflict.ps1 -Path Directory.Packages.props -Specification '<0-1>2<2-5'"
      ]
    },
    {
      "display": "Resolving solution conflict.",
      "stage": "pick",
      "commands": [
        "$repository/.template/scripts/resolve-conflict.ps1 -Path *.slnx -Specification '<0>1'"
      ]
    }
  ]
}
