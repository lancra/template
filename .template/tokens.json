{
  "$schema": "https://raw.githubusercontent.com/lancra/template/main/.template/tokens.schema.json",
  "generated": {
    "GUID": {
      "generator": "./generators/generate-guid.ps1",
      "description": "A globally unique identifier."
    },
    "NUGET_VERSION": {
      "generator": "./generators/generate-nuget-version.ps1",
      "description": "The latest release version of a NuGet package."
    }
  },
  "static": {
    "DOTNET_RUNTIME": {
      "value": "__DOTNET_RUNTIME__",
      "description": "The .NET target framework runtime version.",
      "example": "net8.0"
    },
    "DOTNET_SDK": {
      "value": "__DOTNET_SDK__",
      "description": "The minimum .NET SDK version required to develop the application.",
      "example": "8.0.100"
    },
    "ENVIRONMENT_VARIABLE_PREFIX": {
      "value": "__ENVIRONMENT_VARIABLE_PREFIX__",
      "description": "The prefix used for environment variables specific to the application.",
      "example": "SAMPLE_SOFTWARE"
    },
    "PROJECT": {
      "value": "__PROJECT__",
      "description": "The software name used on solutions and projects.",
      "example": "SampleSoftware"
    },
    "REPOSITORY": {
      "value": "__REPOSITORY__",
      "description": "The name of the software repository.",
      "example": "sample-software"
    },
    "TITLE": {
      "value": "__TITLE__",
      "description": "The title of the software.",
      "example": "Sample Software"
    }
  }
}
